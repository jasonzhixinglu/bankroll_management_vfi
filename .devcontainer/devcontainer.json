{
  "name": "Optimal BRM",
  "image": "mcr.microsoft.com/devcontainers/python:3.11",

  "postCreateCommand": "conda env create -f environment.yml && conda run -n brm pip install -e .",

  "customizations": {
    "vscode": {
      "settings": {
        "terminal.integrated.defaultProfile.linux": "bash"
      },
      "extensions": [
        "ms-python.python",
        "ms-toolsai.jupyter",
        "ms-python.vscode-pylance"
      ]
    }
  }
}
